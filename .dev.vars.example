LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
ANTHROPIC_API_KEY=sk-ant-...
CRON_KEY=any_random_string
FINNHUB_KEY=your_finnhub_api_key
ADMIN_USER=admin_username
ADMIN_PASS=strong_random_password

# Optional — model tier overrides. Defaults are baked into src/claude.js:
#   FAST     = claude-haiku-4-5    (chat, vision, status, cron picks/news)
#   BALANCED = claude-sonnet-4-6   (portfolio analysis + comparison)
#   DEEP     = claude-opus-4-7     (rebalance, with adaptive thinking)
# Override any of them to roll back per task without redeploying the worker.
# CLAUDE_MODEL_FAST=claude-haiku-4-5
# CLAUDE_MODEL_BALANCED=claude-sonnet-4-6
# CLAUDE_MODEL_DEEP=claude-opus-4-7
